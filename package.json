{
  "name": "DiscordBotTemplate",
  "version": "1.0.0",
  "description": "A Discord Bot",
  "main": "dist/index.js",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@11.3.0",
  "scripts": {
    "build": "tsc && tsc-alias",
    "dev": "NODE_ENV=development tsx watch --env-file=.env src/index.ts",
    "start": "NODE_ENV=production node --env-file-if-exists=.env dist/index.js",
    "deploy": "NODE_ENV=development tsx --env-file=.env src/deploy-commands.ts",
    "deploy:prod": "NODE_ENV=production node --env-file-if-exists=.env dist/deploy-commands.js",
    "lint:fix": "eslint . --fix",
    "format:check": "prettier --check .",
    "format": "prettier --write .",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [],
  "author": "Ntalcme",
  "license": "PolyForm-Noncommercial-1.0.0",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.0",
    "dotenv": "^17.4.2",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.9.4",
    "tsc-alias": "^1.8.17",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1"
  },
  "dependencies": {
    "discord.js": "^14.26.4",
    "pino": "^10.3.1"
  },
  "engines": {
    "node": ">=24"
  }
}
